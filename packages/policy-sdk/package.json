{
  "name": "@manasvi/policy-sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@manasvi/contracts": "workspace:*"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -b --pretty false",
    "lint": "tsc --noEmit -p tsconfig.json --pretty false",
    "test": "node -e \"console.log('no tests for policy-sdk')\"",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  }
}
