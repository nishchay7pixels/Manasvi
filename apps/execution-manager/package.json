{
  "name": "@manasvi/execution-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -b --pretty false",
    "lint": "tsc --noEmit -p tsconfig.json --pretty false",
    "test": "node --loader tsx --test src/**/*.test.ts",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@manasvi/auth": "workspace:*",
    "@manasvi/contracts": "workspace:*",
    "@manasvi/executor-sdk": "workspace:*",
    "@manasvi/policy-sdk": "workspace:*",
    "@manasvi/secrets-sdk": "workspace:*",
    "@manasvi/sandbox-runtime": "workspace:*",
    "@manasvi/service-runtime": "workspace:*",
    "@manasvi/tool-sdk": "workspace:*",
    "zod": "^3.24.3"
  }
}
