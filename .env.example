# Shared
MANASVI_ENV=local
LOG_LEVEL=info
HUMAN_LOGS=true
SECRET_PROVIDER=env
SERVICE_VERSION=0.1.0
EVENT_BUS_TARGET_URLS=http://localhost:4102/internal/events
REQUIRE_SIGNED_INTERNAL_EVENTS=true
MAX_EVENT_HANDLER_ATTEMPTS=5
EVENT_SIGNING_KEYS=ingress-key:replace-me
INTERNAL_AUTH_ISSUER=manasvi.internal.auth
INTERNAL_AUTH_AUDIENCE=manasvi.internal.services
INTERNAL_AUTH_KEY_ID=replace-me
INTERNAL_AUTH_SIGNING_SECRET=replace-me
INTERNAL_AUTH_VERIFICATION_KEYS=replace-me-kid:replace-me-secret
INTERNAL_AUTH_TOKEN_TTL_SECONDS=120
POLICY_SERVICE_BASE_URL=http://localhost:4103
POLICY_SET_PATH=configs/policies/default-policy-set.json
POLICY_DECISION_AUDIT_BUFFER_SIZE=500

# Production/staging required secrets (do not commit real values)
INGRESS_SIGNING_KEY_ID=replace-me
ORCHESTRATOR_SIGNING_KEY=replace-me
POLICY_SIGNING_KEY=replace-me
EXECUTION_CONTROL_TOKEN=replace-me
MEMORY_ENCRYPTION_KEY=replace-me
NODE_MANAGER_SIGNING_KEY=replace-me
AUDIT_INTEGRITY_KEY=replace-me
API_GATEWAY_AUTH_TOKEN=replace-me
